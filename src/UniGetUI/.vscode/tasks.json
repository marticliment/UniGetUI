{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build UniGetUI (Debug x64)",
			"type": "process",
			"command": "dotnet",
			"args": [
				"build",
				"${workspaceFolder}/UniGetUI.csproj",
				"--configuration",
				"Debug",
				"/p:Platform=x64"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		}
	]
}