<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="UniGetUI.Avalonia.Controls.DetailDialog">

    <!-- Overlay -->
    <Grid x:Name="Overlay" IsVisible="False">
        <!-- Click-away background -->
        <Border Background="#88000000" PointerPressed="Background_Click" />

        <!-- Dialog card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                MinWidth="650" MaxWidth="900" MinHeight="350" MaxHeight="600"
                Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Margin="40"
                ClipToBounds="True">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Header -->
                <Border Grid.Row="0" Padding="20,16,20,12"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                        <Ellipse x:Name="HeaderDot" Grid.Column="0"
                                 Width="12" Height="12"
                                 Margin="0,0,12,0"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="DialogTitle"
                                       FontSize="16" FontWeight="SemiBold" />
                            <TextBlock x:Name="DialogSubtitle"
                                       FontSize="12" Opacity="0.5"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <!-- Live indicator -->
                        <ProgressBar x:Name="LiveIndicator" Grid.Column="2"
                                     IsIndeterminate="True" Width="80" IsVisible="False"
                                     VerticalAlignment="Center" Margin="0,0,12,0" />
                        <Button Grid.Column="3" Click="CloseButton_Click"
                                Padding="6,4" Background="Transparent" BorderThickness="0"
                                VerticalAlignment="Top">
                            <TextBlock Text="✕" FontSize="16" Opacity="0.5" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer x:Name="ContentScroller" Grid.Row="1" Padding="20,12"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DialogContent"
                               FontSize="12"
                               FontFamily="Menlo, Consolas, monospace"
                               Opacity="0.8"
                               TextWrapping="NoWrap" />
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="20,12"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="LineCountText" FontSize="11" Opacity="0.35"
                                   VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="CopyButton" Content="Copy to Clipboard"
                                    Click="CopyButton_Click" Padding="14,7" />
                            <Button Content="Close" Click="CloseButton_Click" Padding="14,7" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>

</UserControl>
