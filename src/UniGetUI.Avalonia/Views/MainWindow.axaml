<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="using:FluentAvalonia.UI.Controls"
        xmlns:ctrl="using:UniGetUI.Avalonia.Controls"
        xmlns:views="using:UniGetUI.Avalonia.Views"
        x:Class="UniGetUI.Avalonia.Views.MainWindow"
        Title="UniGetUI"
        Width="1400" Height="850"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterScreen">

    <Panel>
        <Grid RowDefinitions="*,Auto,Auto">

            <!-- Row 0: NavigationView (matches WinUI MainView.xaml) -->
            <fa:NavigationView x:Name="NavView"
                               Grid.Row="0"
                               PaneDisplayMode="Left"
                               OpenPaneLength="250"
                               CompactPaneLength="68"
                               IsSettingsVisible="False"
                               IsBackButtonVisible="False"
                               SelectionChanged="NavView_SelectionChanged">

                <fa:NavigationView.MenuItems>
                    <fa:NavigationViewItem Content="Discover Packages" Tag="Discover">
                        <fa:NavigationViewItem.IconSource>
                            <fa:SymbolIconSource Symbol="Find" />
                        </fa:NavigationViewItem.IconSource>
                    </fa:NavigationViewItem>
                    <fa:NavigationViewItem x:Name="NavUpdatesItem" Content="Software Updates" Tag="Updates">
                        <fa:NavigationViewItem.IconSource>
                            <fa:SymbolIconSource Symbol="Up" />
                        </fa:NavigationViewItem.IconSource>
                    </fa:NavigationViewItem>
                    <fa:NavigationViewItem Content="Installed Packages" Tag="Installed">
                        <fa:NavigationViewItem.IconSource>
                            <fa:SymbolIconSource Symbol="List" />
                        </fa:NavigationViewItem.IconSource>
                    </fa:NavigationViewItem>
                </fa:NavigationView.MenuItems>

                <fa:NavigationView.FooterMenuItems>
                    <fa:NavigationViewItem Content="Settings" Tag="Settings">
                        <fa:NavigationViewItem.IconSource>
                            <fa:SymbolIconSource Symbol="Settings" />
                        </fa:NavigationViewItem.IconSource>
                    </fa:NavigationViewItem>
                </fa:NavigationView.FooterMenuItems>

                <!-- NavigationView content area -->
                <Grid RowDefinitions="Auto,*">
                    <!-- Loading banner -->
                    <fa:InfoBar x:Name="LoadingBanner" Grid.Row="0"
                                Title="Loading package managers..."
                                Message="Please wait while UniGetUI initializes."
                                Severity="Informational" IsOpen="True" IsClosable="False">
                        <fa:InfoBar.ActionButton>
                            <ProgressBar IsIndeterminate="True" MinWidth="120" />
                        </fa:InfoBar.ActionButton>
                    </fa:InfoBar>

                    <!-- Content frame -->
                    <ContentControl x:Name="ContentFrame" Grid.Row="1" />
                </Grid>

            </fa:NavigationView>

            <!-- Row 1: Splitter for operations panel -->
            <GridSplitter x:Name="OperationSplitter" Grid.Row="1"
                          Height="12" HorizontalAlignment="Stretch"
                          Background="Transparent"
                          IsVisible="False" />

            <!-- Row 2: Operations panel (matches WinUI MainView operation list) -->
            <Border x:Name="OperationPanel" Grid.Row="2"
                    BorderThickness="0,1,0,0"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    MaxHeight="200"
                    IsVisible="False">
                <Grid RowDefinitions="Auto,*">
                    <!-- Operations header with expand/collapse and menu -->
                    <Border Grid.Row="0" Padding="12,6"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}">
                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                            <fa:SymbolIcon Symbol="Placeholder" FontSize="14" Margin="0,0,8,0"
                                           VerticalAlignment="Center" Opacity="0.6" />
                            <TextBlock Grid.Column="1" Text="Operations" FontSize="13" FontWeight="SemiBold"
                                       Opacity="0.7" VerticalAlignment="Center" />
                            <Button Grid.Column="2" ToolTip.Tip="Retry failed operations"
                                    Click="RetryFailedOps_Click"
                                    Padding="6,4" Classes="theme-borderless" Margin="0,0,2,0">
                                <fa:SymbolIcon Symbol="Sync" FontSize="13" />
                            </Button>
                            <Button Grid.Column="3" ToolTip.Tip="Clear completed"
                                    Click="ClearCompletedOps_Click"
                                    Padding="6,4" Classes="theme-borderless" Margin="0,0,2,0">
                                <fa:SymbolIcon Symbol="Dismiss" FontSize="13" />
                            </Button>
                            <Button Grid.Column="4" ToolTip.Tip="Clear all"
                                    Click="ClearAllOperations_Click"
                                    Padding="6,4" Classes="theme-borderless">
                                <fa:SymbolIcon Symbol="Delete" FontSize="13" />
                            </Button>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1">
                        <ItemsControl x:Name="OperationList" Padding="4" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Package details modal overlay -->
        <Grid x:Name="PackageDetailsOverlay" IsVisible="False">
            <Border Background="#88000000" PointerPressed="PackageDetailsOverlay_BackgroundClick" />
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="950" MinHeight="500" MaxHeight="700"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Margin="40"
                    ClipToBounds="True">
                <Grid RowDefinitions="Auto,*">
                    <!-- Close button header -->
                    <Border Grid.Row="0" Padding="16,8,16,4" HorizontalAlignment="Right">
                        <Button Click="PackageDetailsOverlay_CloseClick"
                                Padding="6,4" Background="Transparent" BorderThickness="0">
                            <TextBlock Text="✕" FontSize="18" Opacity="0.5" />
                        </Button>
                    </Border>
                    <!-- Details page content -->
                    <ContentControl x:Name="PackageDetailsContent" Grid.Row="1" />
                </Grid>
            </Border>
        </Grid>

        <!-- Detail dialog overlay (logs) -->
        <ctrl:DetailDialog x:Name="DetailDialog" />

        <!-- Install options dialog overlay -->
        <views:InstallOptionsDialog x:Name="InstallOptionsOverlay" />
    </Panel>

</Window>
